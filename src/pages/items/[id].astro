---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import itemsData from '../../data/items.json';
import enemiesData from '../../data/enemies.json';

export function getStaticPaths() {
  return Object.entries(itemsData).map(([slug, item]) => ({
    params: { id: slug },
    props: { item },
  }));
}

const slugify = (text) => {
  return text.toString().toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\w-]+/g, '')
    .replace(/--+/g, '-')
    .replace(/^-+/, '')
    .replace(/-+$/, '');
};

const { id } = Astro.params;
const { item } = Astro.props;

const capitalize = (text) => {
  return text.replace(/_/g, ' ').split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
};

const formatValue = (value) => {
    if (typeof value === 'object' && value !== null) {
        return `${value.flat || 0} (Multiplier: ${value.multiplier || 1}x)`;
    }
    return value;
}

const droppedBy = Object.entries(enemiesData)
  .filter(([_, enemy]) => (enemy.loot_list || []).some(loot => loot.item_name === item.id))
  .map(([slug, enemy]) => ({ slug, name: enemy.name }));
---

<StarlightPage frontmatter={{ title: item.name, description: item.description }}>
  <div class="item-details">
    <p>{item.description}</p>


    {item.stats && Object.keys(item.stats).length > 0 && (
      <>
        <h2>Stats</h2>
        <table>
          <thead>
            <tr>
              <th>Stat</th>
              <th>Value</th>
            </tr>
          </thead>
          <tbody>
            {Object.entries(item.stats).map(([stat, value]) => (
              <tr>
                <td>{capitalize(stat)}</td>
                <td>{formatValue(value)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {item.bonus_skill_levels && Object.keys(item.bonus_skill_levels).length > 0 && (
      <>
        <h2>Skill Bonuses</h2>
        <table>
          <thead>
            <tr>
              <th>Skill</th>
              <th>Bonus</th>
            </tr>
          </thead>
          <tbody>
            {Object.entries(item.bonus_skill_levels).map(([skill, bonus]) => (
              <tr>
                <td>{skill}</td>
                <td>+{bonus}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {droppedBy.length > 0 && (
      <>
        <h2>Dropped By</h2>
        <ul>
          {droppedBy.map(enemy => (
            <li>
              <a href={`/YAIRPG-wiki/enemies/${enemy.slug}`}>{enemy.name}</a>
            </li>
          ))}
        </ul>
      </>
    )}
  </div>
</StarlightPage>

<style>
  .item-details {
    margin-top: 1rem;
  }
  .item-details h2 {
    margin-top: 2rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding-bottom: 0.5rem;
  }
  .item-details table {
    width: 100%;
    margin-top: 1rem;
    border-collapse: collapse;
  }
  .item-details th, .item-details td {
    padding: 0.5rem;
    text-align: left;
    border: 1px solid var(--sl-color-gray-5);
  }
  .item-details th {
    background-color: var(--sl-color-gray-6);
    width: 30%;
  }
  .item-details ul {
    list-style: none;
    padding: 0;
  }
  .item-details li {
    margin-bottom: 0.5rem;
  }
  .rarity-trash { color: #808080; }
  .rarity-common { color: #ffffff; }
  .rarity-uncommon { color: #1eff00; }
  .rarity-rare { color: #0070dd; }
  .rarity-epic { color: #a335ee; }
  .rarity-legendary { color: #ff8000; }
  .rarity-mythical { color: #e6cc80; }
</style>
