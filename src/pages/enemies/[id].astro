---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import enemiesData from '../../data/enemies.json';
import locationsData from '../../data/locations.json';

export function getStaticPaths() {
  return Object.entries(enemiesData).map(([slug, enemy]) => ({
    params: { id: slug },
    props: { enemy },
  }));
}

const slugify = (text) => {
  return text.toString().toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\w-]+/g, '')
    .replace(/--+/g, '-')
    .replace(/^-+/, '')
    .replace(/-+$/, '');
};

const { id } = Astro.params;
const { enemy } = Astro.props;

const capitalizeStat = (stat) => {
  return stat.replace(/_/g, ' ').split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
};
---

<StarlightPage frontmatter={{ title: enemy.name, description: enemy.description }}>
  <div class="enemy-details">
    <p>{enemy.description}</p>

    <h2>Stats</h2>
    <table>
      <tbody>
        <tr>
          <td><strong>Health</strong></td>
          <td>{enemy.stats.health}</td>
          <td><strong>Defense</strong></td>
          <td>{enemy.stats.defense}</td>
        </tr>
        <tr>
          <td><strong>Attack Power</strong></td>
          <td>{enemy.stats.attack}</td>
          <td><strong>Attack Speed</strong></td>
          <td>{enemy.stats.attack_speed}</td>
        </tr>
        <tr>
          <td><strong>AP</strong></td>
          <td>{enemy.base_AP}</td>
          <td><strong>EP</strong></td>
          <td>{enemy.base_EP}</td>
        </tr>
      </tbody>
    </table>

    {enemy.location_combat_stats && enemy.location_combat_stats.length > 0 && (
      <>
        <h2>Locations</h2>
        <table>
          <thead>
            <tr>
              <th>Location</th>
              <th>Repeatable</th>
              <th>Max Group Size</th>
              <th>Stat Variation</th>
              <th>Character AP for 100% Hit</th>
              <th>Character EP for 100% Dodge</th>
            </tr>
          </thead>
          <tbody>
            {enemy.location_combat_stats.map(stat => (
              <tr>
                <td>
                  <a href={`/YAIRPG-wiki/locations/${stat.location_id}`}>
                    {stat.location_name}
                  </a>
                </td>
                <td>{locationsData[stat.location_id]?.is_farmable ? 'Yes' : 'No'}</td>
                <td>{stat.max_enemies} {stat.max_enemies > 1 ? 'enemies' : 'enemy'}</td>
                <td>{Math.round(stat.stat_variation * 100)}%</td>
                <td>{stat.ap_to_hit}</td>
                <td>{stat.evasion_to_dodge}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {enemy.loot_list.length > 0 && (
      <>
        <h2>Loot Table</h2>
        <table>
          <thead>
            <tr>
              <th>Item</th>
              <th>Chance</th>
            </tr>
          </thead>
          <tbody>
            {enemy.loot_list.map(loot => (
              <tr>
                <td>
                  <a href={`/YAIRPG-wiki/items/${slugify(loot.item_name)}`}>
                    {loot.item_name}
                  </a>
                </td>
                <td>{(loot.chance * 100).toFixed(2)}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}
  </div>
</StarlightPage>

<style>
  .enemy-details {
    margin-top: 1rem;
  }
  .enemy-details h2 {
    margin-top: 2rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding-bottom: 0.5rem;
  }
  .enemy-details ul {
    list-style: none;
    padding: 0;
  }
  .enemy-details li {
    margin-bottom: 0.5rem;
  }
  .enemy-details table {
    width: 100%;
    margin-top: 1rem;
    border-collapse: collapse;
  }
  .enemy-details th, .enemy-details td {
    padding: 0.5rem;
    text-align: left;
    border: 1px solid var(--sl-color-gray-5);
  }
  .enemy-details th {
    background-color: var(--sl-color-gray-6);
  }
</style>
