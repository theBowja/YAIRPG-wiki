---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import enemiesData from '../../data/enemies.json';
import locationsData from '../../data/locations.json';

export function getStaticPaths() {
  return Object.entries(enemiesData).map(([slug, enemy]) => ({
    params: { id: slug },
    props: { enemy },
  }));
}

const slugify = (text) => {
  return text.toString().toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\w-]+/g, '')
    .replace(/--+/g, '-')
    .replace(/^-+/, '')
    .replace(/-+$/, '');
};

const { id } = Astro.params;
const { enemy } = Astro.props;

const capitalizeStat = (stat) => {
  return stat.replace(/_/g, ' ').split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
};

const foundInLocations = Object.entries(locationsData)
  .filter(([_, loc]) => loc.is_combat_zone && loc.enemies_list.includes(enemy.id))
  .map(([slug, loc]) => ({ slug, name: loc.name }));
---

<StarlightPage frontmatter={{ title: enemy.name, description: enemy.description }}>
  <div class="enemy-details">
    <p>{enemy.description}</p>

    {foundInLocations.length > 0 && (
      <>
        <h2>Found in Locations</h2>
        <ul>
          {foundInLocations.map(loc => (
            <li>
              <a href={`/YAIRPG-wiki/locations/${loc.slug}`}>{loc.name}</a>
            </li>
          ))}
        </ul>
      </>
    )}

    <h2>Combat Stats</h2>
    <table>
      <thead>
        <tr>
          <th>Combat Stat</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Base AP (Attack Points)</td>
          <td>{enemy.base_AP}</td>
        </tr>
        <tr>
          <td>Base EP (Evasion Points)</td>
          <td>{enemy.base_EP}</td>
        </tr>
        <tr>
          <td>Evasion for 100% Dodge <br/><small>(accounts for max stat variation)</small></td>
          <td>{enemy.evasion_to_dodge}</td>
        </tr>
      </tbody>
    </table>

    <h2>Base Stats</h2>
    <table>
      <thead>
        <tr>
          <th>Stat</th>
          <th>Value</th>
        </tr>
      </thead>
      <tbody>
        {Object.entries(enemy.stats).map(([stat, value]) => (
          <tr>
            <td>{capitalizeStat(stat)}</td>
            <td>{value}</td>
          </tr>
        ))}
      </tbody>
    </table>

    {enemy.loot_list.length > 0 && (
      <>
        <h2>Loot Table</h2>
        <table>
          <thead>
            <tr>
              <th>Item</th>
              <th>Chance</th>
            </tr>
          </thead>
          <tbody>
            {enemy.loot_list.map(loot => (
              <tr>
                <td>{loot.item_name}</td>
                <td>{(loot.chance * 100).toFixed(2)}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}
  </div>
</StarlightPage>

<style>
  .enemy-details {
    margin-top: 1rem;
  }
  .enemy-details h2 {
    margin-top: 2rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding-bottom: 0.5rem;
  }
  .enemy-details ul {
    list-style: none;
    padding: 0;
  }
  .enemy-details li {
    margin-bottom: 0.5rem;
  }
  .enemy-details table {
    width: 100%;
    margin-top: 1rem;
    border-collapse: collapse;
  }
  .enemy-details th, .enemy-details td {
    padding: 0.5rem;
    text-align: left;
    border: 1px solid var(--sl-color-gray-5);
  }
  .enemy-details th {
    background-color: var(--sl-color-gray-6);
  }
</style>
