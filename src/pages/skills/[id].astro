---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import skillsData from '../../data/skills.json';

export function getStaticPaths() {
  return Object.entries(skillsData).map(([slug, skill]) => ({
    params: { id: slug },
    props: { skill },
  }));
}

const { id } = Astro.params;
const { skill } = Astro.props;

const slugify = (text) => {
  return text.toString().toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\w-]+/g, '')
    .replace(/--+/g, '-')
    .replace(/^-+/, '')
    .replace(/-+$/, '');
};
---

<StarlightPage frontmatter={{ title: skill.name, description: skill.description }}>
  <div class="skill-details">
    <p>{skill.description}</p>
    {skill.flavour_text && (
      <p><em>{skill.flavour_text}</em></p>
    )}

    {skill.sources && (
      <div class="xp-sources">
        <h2>XP Sources</h2>
        
        {skill.sources.activities?.length > 0 && (
          <section>
            <h3>Activities</h3>
            <ul>
              {skill.sources.activities.map(activity => (
                <li>
                  <strong><a href={`/YAIRPG-wiki/activities/${activity.id}`}>{activity.name}</a></strong>
                  {activity.locations?.length > 0 && (
                    <span> in {activity.locations.map((loc, i) => (
                      <span>
                        <a href={`/YAIRPG-wiki/locations/${slugify(loc.id)}`}>{loc.name}</a>
                        {i < activity.locations.length - 1 ? ', ' : ''}
                      </span>
                    ))}</span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        )}

        {skill.sources.locations?.length > 0 && (
          <section>
            <h3>Environment</h3>
            <ul>
              {skill.sources.locations.map(loc => (
                <li>
                  <a href={`/YAIRPG-wiki/locations/${slugify(loc.id)}`}>{loc.name}</a> ({loc.type})
                </li>
              ))}
            </ul>
          </section>
        )}

        {skill.sources.recipes?.length > 0 && (
          <section>
            <h3>Recipes</h3>
            <ul>
              {skill.sources.recipes.map(recipe => (
                <li>
                  <a href={`/YAIRPG-wiki/recipes/${recipe.slug}`}>{recipe.name}</a> (Level {recipe.level})
                </li>
              ))}
            </ul>
          </section>
        )}

        {skill.sources.combat?.length > 0 && (
          <section>
            <h3>Combat</h3>
            <ul>
              {skill.sources.combat.map(combat => (
                <li>
                  {combat.description}
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>
    )}
  </div>
</StarlightPage>

<style>
  .skill-details {
    margin-top: 1rem;
  }
  .skill-details h2 {
    margin-top: 2rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding-bottom: 0.5rem;
  }
  .skill-details ul {
    list-style: none;
    padding: 0;
  }
  .skill-details li {
    margin-bottom: 0.5rem;
  }
  .xp-sources section {
    margin-top: 1.5rem;
  }
  .xp-sources h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: var(--sl-color-gray-3);
  }
</style>
